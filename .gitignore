__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.Python

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
env/
.venv/
.env/

# -----------------------------------------------------------------------------
