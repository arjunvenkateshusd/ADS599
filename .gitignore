# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------
.vscode/settings.json
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------------
